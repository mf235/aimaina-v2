1000 'AIMAINA
1010 SCREEN 5:OPEN"GRP:"AS#1:COLOR 1,15,15:CLS
1020 OX=74:OY=37
1030 READ T$
1040 IF T$="L" THEN 1100
1050 IF T$="C" THEN 1200
1060 IF T$="P" THEN 1300
1070 IF T$="S" THEN 1400
1080 IF T$="E" THEN 1900
1090 GOTO 1030
1100 'LINE
1110 READ A,B,C,D
1120 LINE(OX+A,OY+B)-(OX+C,OY+D),1
1130 READ A,B
1140 IF A<0 THEN 1030
1150 LINE -(OX+A,OY+B),1
1160 GOTO 1130
1200 'CIRCLE
1210 READ A,B,C
1220 CIRCLE(OX+A,OY+B),C,1
1230 GOTO 1030
1300 'PAINT
1310 READ A,B,C
1320 PAINT(OX+A,OY+B),C,1
1330 GOTO 1030
1400 'STR
1410 READ A,B,C$
1420 PSET(OX+A,OY+B):PRINT #1,C$
1430 GOTO 1030
1900 'END
1910 FOR I=0 TO 30000:NEXT I
1920 END
2020 'AIMAINA-CHAN V2 (COLOR)
2030 'FACE OUTLINE
2040 DATA "C",50,45,25
2050 'LEFT TWINTAIL (CLOSED PATH FOR PAINTING)
2060 DATA "L",26,38,10,75,20,80,26,55,26,38,-1,-1
2070 'RIGHT TWINTAIL (CLOSED PATH)
2080 DATA "L",74,38,90,75,80,80,74,55,74,38,-1,-1
2090 'HAIR PAINT (MSX COLOR 7: CYAN)
2100 DATA "P",18,70,7
2110 DATA "P",82,70,7
2120 'LEFT EYE (CIRCLE)
2130 DATA "C",38,45,8
2140 'LEFT EYE PAINT (MSX COLOR 8: RED)
2150 DATA "P",35,45,8
2160 'LEFT PUPIL (SLIT)
2170 DATA "L",38,40,38,50,-1,-1
2180 'RIGHT EYE (CIRCLE)
2190 DATA "C",62,45,8
2200 'RIGHT EYE PAINT (MSX COLOR 8: RED)
2210 DATA "P",59,45,8
2220 'RIGHT PUPIL (SLIT)
2230 DATA "L",62,40,62,50,-1,-1
2240 'DRESS
2250 DATA "L",35,68,65,68,75,100,25,100,35,68,-1,-1
2260 'DRESS PAINT (MSX COLOR 4: DARK BLUE)
2270 DATA "P",50,85,4
2280 'TEXT
2290 DATA "S",6,115,"AIMAINA V2"
2300 DATA "S",6,125,"COLOR EDITION!"
9000 'END
9010 DATA "E"
